# recskit's core needs no configuration at all -- it's pure Python
# with no external connections.
#
# The variables below are only relevant if you're using the optional
# Sage 50 adapter (recskit.sage_adapter) via the "sage" extra, and they
# come from sagekit -- see its README for details. Copy this file to
# .env if you want to pre-fill them; leave SAGE_PWD unset to be
# prompted safely instead.

SAGE_DSN=SageLine50v33
SAGE_UID=MANAGER
SAGE_PWD=
